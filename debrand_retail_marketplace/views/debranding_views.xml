<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Debrand Backend Login Layout -->
    <template id="login_layout_debrand" inherit_id="web.login_layout">
        <!-- Hide/replace Odoo branding in the login page footer -->
        <xpath expr="//div[hasclass('text-center')]" position="replace">
            <div class="text-center small mt-4" style="color: #666;">
                <span>Powered by Custom Retail &amp; Marketplace Solutions</span>
            </div>
        </xpath>
    </template>

    <!-- Debrand Web Layout / Browser Title -->
    <template id="layout_debrand" inherit_id="web.layout">
        <!-- Remove "Odoo" references in web titles -->
        <xpath expr="//title" position="replace">
            <title t-esc="title or 'Retail &amp; E-Commerce Portal'" />
        </xpath>
    </template>
</odoo>
